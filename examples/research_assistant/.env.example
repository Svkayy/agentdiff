# Local Ollama (OpenAI-compatible endpoint). No real secrets — "ollama" is a
# placeholder key the Ollama server ignores.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
AGENT_MODEL=llama3.1:8b

# AgentDiff's own judge + attribution explainer also talk to Ollama.
AGENTDIFF_LLM_PROVIDER=openai
AGENTDIFF_LLM_MODEL=llama3.1:8b
