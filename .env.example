# AgentDiff environment variables — copy to .env and fill in real values.
# Never commit your .env file.

# ── Required: API server ─────────────────────────────────────────────────────

# 32-byte URL-safe base64 Fernet key used to encrypt Slack tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENTDIFF_SECRET_ENCRYPTION_KEY=

# Clerk JWKS endpoint for verifying dashboard JWTs.
# Found in Clerk dashboard → API Keys → Advanced → JWKS URL.
# Example: https://<your-clerk-frontend-api>/.well-known/jwks.json
AGENTDIFF_CLERK_JWKS_URL=

# Clerk issuer (your Clerk Frontend API URL, no trailing slash).
# Example: https://<your-clerk-frontend-api>
AGENTDIFF_CLERK_ISSUER=

# ── Required: Dashboard (baked into the Vite build) ─────────────────────────

# Clerk publishable key for the React dashboard.
# Found in Clerk dashboard → API Keys → Publishable key.
# Example: pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=

# Public URL of the API service reachable from the user's browser.
# In local compose: http://localhost:8000
# In production: https://api.yourdomain.com
VITE_AGENTDIFF_API_URL=http://localhost:8000

# ── Slack OAuth (platform-level — owner registers ONE Slack app) ─────────────
# Register your Slack app at https://api.slack.com/apps
# Required scopes: incoming-webhook, chat:write, channels:join
# AgentDiff posts as a bot member of the chosen channel (public channels: it
# auto-joins via conversations.join and is @mentionable in the member list).
# Private channels: the bot cannot self-join, so it falls back to the webhook URL.
# Redirect URL must be: <api-url>/v1/slack/callback
# NOTE: Slack requires an HTTPS redirect URL. For local dev use an
#       ngrok/cloudflared tunnel pointing to port 8000, e.g.:
#         ngrok http 8000  → set AGENTDIFF_SLACK_REDIRECT_URL=https://<id>.ngrok.io/v1/slack/callback
AGENTDIFF_SLACK_CLIENT_ID=
AGENTDIFF_SLACK_CLIENT_SECRET=
AGENTDIFF_SLACK_REDIRECT_URL=http://localhost:8000/v1/slack/callback
AGENTDIFF_DASHBOARD_URL=http://localhost:5173

# ── LLM explanations (optional) ──────────────────────────────────────────────
# When set, the hosted worker produces a 1-3 sentence LLM explanation for each
# detected behavioral change. If unset, the deterministic rule-based explanation
# is used (always available, no key required).
# AGENTDIFF_ANTHROPIC_API_KEY=sk-ant-...
# Model override (default: claude-3-5-haiku-20241022):
# AGENTDIFF_LLM_MODEL=claude-3-5-haiku-20241022

# ── Optional tuning ──────────────────────────────────────────────────────────

# Sliding window for drift detection (minutes). Default: 1440 (24 h).
# Reduce only if you have very high agent traffic (thousands of runs/day).
# AGENTDIFF_DRIFT_WINDOW_MINUTES=1440

# Max POST /v1/runs calls accepted per project per minute. Default: 60.
# AGENTDIFF_RATE_LIMIT_RUNS_PER_MINUTE=60

# Comma-separated origins allowed by the API's CORS middleware.
# Default: http://localhost:5173 (compose dashboard).
# In production set this to EXACTLY your dashboard origin(s), never '*':
# AGENTDIFF_CORS_ORIGINS=https://app.yourdomain.com

# ── Usage metering / quotas ──────────────────────────────────────────────────
# Monthly caps for the free plan. 'pro' / 'unlimited' plans have no cap.
# AGENTDIFF_FREE_RUNS_PER_MONTH=500
# AGENTDIFF_FREE_TRAJECTORIES_PER_MONTH=50000

# ── Retention (days) ─────────────────────────────────────────────────────────
# Runs older than this are deleted by the daily retention cron; 0 disables.
# AGENTDIFF_RETENTION_DAYS=90
# LiveTrajectories older than this are deleted by the same cron; 0 disables.
# AGENTDIFF_LIVE_RETENTION_DAYS=30

# ── Observability ────────────────────────────────────────────────────────────
# Optional Sentry DSN — when set, the worker calls sentry_sdk.init (guarded
# import; install sentry-sdk to use).
# AGENTDIFF_SENTRY_DSN=
